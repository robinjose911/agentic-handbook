flowchart TB
  start(["Task to automate"]) --> q1{"Deterministic, fixed<br/>set of steps?"}
  q1 -->|Yes| code["Write plain code<br/>(no LLM)"]:::external
  q1 -->|No| q2{"Does it need a<br/>model's judgement?"}
  q2 -->|"Single judgement"| call["One LLM call<br/>+ structured output"]:::primary
  q2 -->|"Several known steps"| q3{"Steps known<br/>in advance?"}
  q3 -->|Yes| wf["Workflow:<br/>chain / route / parallelize"]:::secondary
  q3 -->|"No — model must<br/>choose its own path"| q4{"How much autonomy<br/>can you allow? (L0-L4)"}
  q4 -->|"L1-L2: act with<br/>approval / guardrails"| agentG["Agent loop<br/>inside hard limits<br/>+ HITL gates"]:::primary
  q4 -->|"L3: act unattended<br/>in a bounded domain"| agentA["Autonomous agent<br/>+ evals + kill switch"]:::tertiary
  q4 -->|"L4: self-directed,<br/>cross-domain"| stop["Stop. Prohibited tier —<br/>redesign the scope"]:::tertiary

  classDef primary fill:#F1EFFA,stroke:#714EC4,stroke-width:2px,color:#2A2A2A
  classDef secondary fill:#E7F2FF,stroke:#0E6995,stroke-width:2px,color:#2A2A2A
  classDef tertiary fill:#FFF4E6,stroke:#E1AB2F,stroke-width:2px,color:#2A2A2A
