flowchart TB
  L0["L0 — Suggest-only<br/>drafts; human does everything<br/>EU: minimal risk"]:::secondary
  L1["L1 — Act-with-approval<br/>human approves each action<br/>EU: limited risk"]:::secondary
  L2["L2 — Act-with-guardrails<br/>acts inside hard limits; post-hoc review<br/>EU: limited risk"]:::primary
  L3["L3 — Act-autonomously<br/>unattended in a bounded domain; HITL on exceptions<br/>EU: high-risk"]:::tertiary
  L4["L4 — Self-directed<br/>sets its own cross-domain goals<br/>EU: prohibited"]:::tertiary
  L0 --> L1 --> L2 --> L3 --> L4
  guard["Each step up adds: tighter evals,<br/>a kill switch, and a heavier audit trail."]:::external
  L2 -.-> guard

  classDef primary fill:#F1EFFA,stroke:#714EC4,stroke-width:2px,color:#2A2A2A
  classDef secondary fill:#E7F2FF,stroke:#0E6995,stroke-width:2px,color:#2A2A2A
  classDef tertiary fill:#FFF4E6,stroke:#E1AB2F,stroke-width:2px,color:#2A2A2A
  classDef external fill:#F0F0F0,stroke:#808080,stroke-width:1.5px,color:#404040,stroke-dasharray: 4 2
