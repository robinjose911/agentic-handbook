flowchart LR
  subgraph DUR["Outer durable workflow (survives restarts)"]
    direction LR
    s1["Step: enrich"]:::secondary --> ckpt1[("checkpoint")]:::external
    ckpt1 --> s2["Step: agent loop"]:::primary
    s2 --> ckpt2[("checkpoint")]:::external
    ckpt2 --> s3["Step: act / write"]:::secondary
  end
  s2 -.->|"inner loop, budget-capped"| inner["LLM <-> tools<br/>(retry / idempotent)"]:::primary
  s3 --> hitl{"HITL gate<br/>before side effects"}:::tertiary
  hitl -->|Approved| done(["Committed + logged"])
  hitl -->|Rejected| comp["Compensate / rollback"]:::tertiary

  classDef primary fill:#F1EFFA,stroke:#714EC4,stroke-width:2px,color:#2A2A2A
  classDef secondary fill:#E7F2FF,stroke:#0E6995,stroke-width:2px,color:#2A2A2A
  classDef tertiary fill:#FFF4E6,stroke:#E1AB2F,stroke-width:2px,color:#2A2A2A
  classDef external fill:#F0F0F0,stroke:#808080,stroke-width:1.5px,color:#404040,stroke-dasharray: 4 2
