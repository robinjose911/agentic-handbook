flowchart TB
  prop["Agent proposes a tool call<br/>(args + intent)"]:::primary --> risk{"Risk tier of<br/>the action?"}
  risk -->|"read-only / low"| auto["Auto-execute<br/>inside guardrails"]:::secondary
  risk -->|"writes / spends / external"| gate["HITL approval gate"]:::tertiary
  gate -->|Approved| exec["Execute tool"]:::secondary
  gate -->|Rejected| log["Log + return reason<br/>to the agent"]:::tertiary
  auto --> audit["Append to audit log"]:::secondary
  exec --> audit
  log --> audit

  classDef primary fill:#F1EFFA,stroke:#714EC4,stroke-width:2px,color:#2A2A2A
  classDef secondary fill:#E7F2FF,stroke:#0E6995,stroke-width:2px,color:#2A2A2A
  classDef tertiary fill:#FFF4E6,stroke:#E1AB2F,stroke-width:2px,color:#2A2A2A
  classDef external fill:#F0F0F0,stroke:#808080,stroke-width:1.5px,color:#404040,stroke-dasharray: 4 2
