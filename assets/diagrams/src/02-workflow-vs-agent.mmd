flowchart TB
  subgraph WF["Workflow — you wire the path"]
    direction LR
    w1["Step 1"]:::secondary --> w2["Step 2"]:::secondary --> w3["Step 3"]:::secondary --> wout(["Output"])
  end
  subgraph AG["Agent — the model wires the path"]
    direction LR
    a0(["Goal"]) --> a1["LLM plans + acts"]:::primary
    a1 <-->|"tools + observations"| a2["Environment"]:::secondary
    a1 --> aout(["Output"])
  end
  note["Prefer a workflow when steps are known.<br/>Reach for an agent only when the path is dynamic."]:::tertiary
